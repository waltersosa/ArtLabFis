\def\@LN@column{1}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Bland--Altman analysis by sensor: agreement between in-person and remote modality.}}{14}{table.caption.11}\protected@file@percent }
\newlabel{tab:bland_altman}{{5}{14}{Bland--Altman analysis by sensor: agreement between in-person and remote modality}{table.caption.11}{}}
\newlabel{tab:bland_altman@cref}{{[table][5][]5}{[1][13][]14}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Bland--Altman analysis for sensors S2, S3, and S4. Each panel shows the difference between in-person and remote measurements ($x_P - y_R$) versus their mean $\frac  {x_P + y_R}{2}$. The solid black line represents the mean bias ($\bar  {d}$); the dashed red lines delimit the 95\% limits of agreement ($\bar  {d} \pm 1{,}96\,\sigma _d$); the dotted gray line marks zero difference. The random distribution of the points, without funnel-shaped pattern, confirms the absence of proportional systematic bias in the IoT system across the entire measurement range.}}{14}{figure.caption.12}\protected@file@percent }
\newlabel{fig:bland_altman}{{7}{14}{Bland--Altman analysis for sensors S2, S3, and S4. Each panel shows the difference between in-person and remote measurements ($x_P - y_R$) versus their mean $\frac {x_P + y_R}{2}$. The solid black line represents the mean bias ($\bar {d}$); the dashed red lines delimit the 95\% limits of agreement ($\bar {d} \pm 1{,}96\,\sigma _d$); the dotted gray line marks zero difference. The random distribution of the points, without funnel-shaped pattern, confirms the absence of proportional systematic bias in the IoT system across the entire measurement range}{figure.caption.12}{}}
\newlabel{fig:bland_altman@cref}{{[figure][7][]7}{[1][14][]14}{}{}{}}
